{
  "name": "photodedup",
  "version": "1.3.1",
  "description": "Nextcloud Photo Deduplicator",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "lint": "eslint --ext .js,.vue src/",
    "lint:fix": "eslint --ext .js,.vue --fix src/",
    "stylelint": "stylelint 'src/**/*.vue' 'css/**/*.css'",
    "stylelint:fix": "stylelint --fix 'src/**/*.vue' 'css/**/*.css'",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:list": "playwright test --list"
  },
  "dependencies": {
    "@nextcloud/axios": "^2.5.0",
    "@nextcloud/router": "^3.0.0",
    "@nextcloud/vue": "^8.0.0",
    "leaflet": "^1.9.4",
    "vue": "^2.7.16",
    "vue-material-design-icons": "^5.3.0"
  },
  "devDependencies": {
    "@nextcloud/babel-config": "^1.2.0",
    "@nextcloud/browserslist-config": "^3.1.2",
    "@nextcloud/eslint-config": "^8.4.1",
    "@nextcloud/stylelint-config": "^3.0.1",
    "@nextcloud/webpack-vue-config": "^7.0.2",
    "@playwright/test": "^1.58.2",
    "vue-loader": "^15.11.1",
    "webpack": "^5.91.0",
    "webpack-cli": "^6.0.1"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ]
}
